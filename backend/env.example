# Copy this file to .env and fill in your real values
# NEVER commit .env to Git!

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://yourUsername:yourPassword@cluster0.xxxxx.mongodb.net/csc300l?retryWrites=true&w=majority

# Port the server listens on (Render sets this automatically)
PORT=5000

# Your Vercel frontend URL (no trailing slash)
# e.g. https://school-form.vercel.app
FRONTEND_URL=https://your-app.vercel.app
